# Supabase Configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Admin Configuration (server-side only - DO NOT expose to client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
ADMIN_EMAIL=admin@modart.com
ADMIN_PASSWORD_HASH=your-bcrypt-hash-here

# API Configuration
VITE_API_BASE_URL=https://modart.com/api

# Email Configuration (server-side only)
SENDGRID_API_KEY=your-sendgrid-key-here
FROM_EMAIL=noreply@modart.com

# Redis Configuration (server-side only)
REDIS_URL=redis://default:password@redis.upstash.io:6379
REDIS_TOKEN=your-redis-token-here

# Environment
NODE_ENV=production

# Security
SESSION_SECRET=your-random-secret-here
CSRF_SECRET=your-random-secret-here

# Monitoring (optional)
SENTRY_DSN=your-sentry-dsn-here

# Instructions:
# 1. Copy this file to .env
# 2. Replace all placeholder values with actual credentials
# 3. NEVER commit .env to git
# 4. Add .env to .gitignore
